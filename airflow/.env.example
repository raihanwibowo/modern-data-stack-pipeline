AIRFLOW_UID=502

# Airbyte Configuration
AIRBYTE_URL=http://host.docker.internal:8000
AIRBYTE_USERNAME=your-airbyte-username
AIRBYTE_PASSWORD=your-airbyte-password

# Airbyte Connection IDs (get from Airbyte UI)
AIRBYTE_CONNECTION_ID_1=your-connection-id-1
AIRBYTE_CONNECTION_ID_2=your-connection-id-2
AIRBYTE_POSTGRES_TO_CLICKHOUSE_CONNECTION_ID=your-postgres-to-clickhouse-connection-id

# ClickHouse Configuration
CLICKHOUSE_HOST=host.docker.internal
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your-clickhouse-password
CLICKHOUSE_DATABASE=analytics
